include "stdio.h";

enum TestEnum {
    NoArgs;
    WithDefault(a: Int, b: Int = 100);
    WithTwoDefaults(x: Float, y: Float = 2.5, z: Int = 42);
}

function main() {
    var e1 = WithDefault(10);
    var e2 = WithTwoDefaults(1.5);
    var e3 = WithTwoDefaults(1.5, 3.0);

    printf("e1.a = %i, e1.b = %i\n", e1.a, e1.b);
    printf("e2.x = %f, e2.y = %f, e2.z = %i\n", e2.x, e2.y, e2.z);
    printf("e3.x = %f, e3.y = %f, e3.z = %i\n", e3.x, e3.y, e3.z);
}
